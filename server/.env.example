# LIV8 AI Server Configuration
# =============================
# Copy this file to .env and fill in your API keys

# Primary AI Provider (gemini recommended — free; claude used auto for code tasks)
AI_PROVIDER=gemini

# Anthropic (Claude) Configuration
ANTHROPIC_API_KEY=your_anthropic_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI (GPT) Configuration - Add your key to enable GPT
OPENAI_API_KEY=
GPT_MODEL=gpt-4o

# Google Gemini Configuration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq Configuration (FREE - Llama 3.3, Mixtral, Gemma)
# Get free key at: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Kimi / NVIDIA NIM API Configuration
KIMI_API_KEY=
# Or use: NVIDIA_API_KEY=

# VoxCPM (Free, self-hosted TTS with voice cloning)
# Run on a GPU server: pip install voxcpm && python -m voxcpm.server --port 8808
# Then set the URL here. Leave empty to use OpenAI/Kokoro/Edge TTS instead.
VOXCPM_BASE_URL=

# Server Configuration
PORT=3005

# Freshdesk Configuration (for scheduled polling)
FRESHDESK_DOMAIN=your_freshdesk_domain
FRESHDESK_API_KEY=your_freshdesk_api_key
FRESHDESK_AGENT_ID=your_agent_id

# Scheduled Polling (cron expressions in EST timezone)
SCHEDULE_ENABLED=true
SCHEDULE_TIMEZONE=America/New_York
SCHEDULE_MORNING=0 8 * * *
SCHEDULE_NOON=0 12 * * *
SCHEDULE_AFTERNOON=0 16 * * *
SCHEDULE_MIDNIGHT=0 0 * * *

# Webhook Integration for notifications
TASKMAGIC_WEBHOOK_URL=your_taskmagic_webhook_url
N8N_WEBHOOK_URL=

# TaskMagic MCP Server
TASKMAGIC_MCP_TOKEN=your_taskmagic_token

# Google Calendar Integration
GOOGLE_CALENDAR_EMAIL=your_email@gmail.com

# Financial News & Market Data APIs
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
FINNHUB_API_KEY=your_finnhub_key

# Taskade Integration
TASKADE_API_KEY=

# GoHighLevel (GHL) Integration
GHL_API_KEY=
GHL_LOCATION_ID=

# Supabase Integration
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Nifty PM Integration (OAuth 2.0)
NIFTY_CLIENT_ID=your_client_id
NIFTY_CLIENT_SECRET=your_client_secret
NIFTY_REDIRECT_URI=https://your-app.com/api/nifty/callback
NIFTY_ACCESS_TOKEN=
NIFTY_REFRESH_TOKEN=

# Web Scraping APIs
RAPIDAPI_KEY=
APIFY_API_KEY=

# Hybrid Journal API (for iOS Shortcuts bridge)
HYBRID_JOURNAL_API_KEY=your_hj_api_key

# ============================================
# TELEGRAM BRIDGE (Voice ↔ Telegram ↔ Trading)
# ============================================

# Your Telegram Bot Token (create via @BotFather)
TELEGRAM_BOT_TOKEN=

# Chat IDs for each channel (get via @userinfobot or from Telegram API)
TELEGRAM_JUNO_CHAT_ID=         # Juno / OpenClaw bot chat
TELEGRAM_SIGNALS_CHAT_ID=      # Smart Auto Trader signals channel
TELEGRAM_KRAKEN_CHAT_ID=       # Kraken Pro trading bot chat
TELEGRAM_COMMUNITY_CHAT_ID=    # Community group

# ============================================
# LIVE STREAMING (RTMP Multistream)
# ============================================

# Viloud - Trade Hybrid TV
VILOUD_RTMP_URL=rtmp://broadcast.viloud.tv/in/
VILOUD_STREAM_KEY=your_viloud_stream_key

# GoKollab Community
GOKOLLAB_RTMP_URL=your_gokollab_rtmp_url
GOKOLLAB_STREAM_KEY=your_gokollab_stream_key

# YouTube Live
YOUTUBE_STREAM_KEY=

# Twitch
TWITCH_STREAM_KEY=

# Facebook Live
FACEBOOK_STREAM_KEY=

# Custom RTMP destinations (up to 3)
# CUSTOM_RTMP_URL_1=rtmp://your-custom-server/live
# CUSTOM_RTMP_KEY_1=your_stream_key
# CUSTOM_RTMP_NAME_1=My Custom Stream

# Database
DATABASE_PATH=./data/liv8.db
